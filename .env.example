# Application
APP_ENV=development
APP_NAME=Industrial Maintenance Knowledge Copilot
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
POSTGRES_HOST_PORT=5433
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_INTERNAL_BASE_URL=http://api:8000

# PostgreSQL
POSTGRES_DB=maintenance_copilot
POSTGRES_USER=maintenance
POSTGRES_PASSWORD=maintenance
DATABASE_URL=postgresql+psycopg://maintenance:maintenance@postgres:5432/maintenance_copilot

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Optional Redis
REDIS_URL=redis://redis:6379/0

# Storage
UPLOAD_DIR=/app/data/uploads
PARSED_DIR=/app/data/parsed
RENDERED_PAGES_DIR=/app/data/rendered-pages
MAX_UPLOAD_MB=50
MAX_BATCH_FILES=20
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.docx,.xlsx,.csv,.txt,.png,.jpg,.jpeg
OCR_ENABLED=true
OCR_LANGUAGE=eng
OCR_MIN_TEXT_CHARACTERS=30
PAGE_RENDER_DPI=150
CHUNK_TARGET_TOKENS=500
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=75

# Structured extraction
EXTRACTION_ENABLED=true
EXTRACTION_PROVIDER=mock
EXTRACTION_MODEL=maintenance-extraction-mock
EXTRACTION_API_BASE_URL=
EXTRACTION_API_KEY=
EXTRACTION_TIMEOUT_SECONDS=30
EXTRACTION_MAX_RETRIES=2
EXTRACTION_CONCURRENCY=1
EXTRACTION_MIN_CONFIDENCE=0.55
EXTRACTION_AUTO_ACCEPT_CONFIDENCE=0.85
EXTRACTION_MAX_CHUNK_CHARACTERS=6000
EXTRACTION_PROMPT_VERSION=maintenance_extraction_v1
OLLAMA_BASE_URL=http://localhost:11434

# Future retrieval providers — not used in Phase 5
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
RERANK_PROVIDER=
RERANK_MODEL=

# Security
SECRET_KEY=replace-this-in-real-environments
CORS_ORIGINS=http://localhost:3000
